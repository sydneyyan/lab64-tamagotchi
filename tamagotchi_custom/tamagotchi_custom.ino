const unsigned char* centerFrames[] = { epd_bitmap_c1, epd_bitmap_c2 };
const unsigned char* leftFrames[]   = {epd_bitmap_l2, epd_bitmap_l3};
const unsigned char* rightFrames[]  = {	epd_bitmap_r1, epd_bitmap_r2}; 

// *******************************************************************************************************************
// OPTIONAL TODO: If you add your own frames, make sure you add the amount of frames you want for each button animation
// *******************************************************************************************************************

// Total frames available for each cycle
const int FRAME_COUNT = 2;
const int TOTAL_CENTER_FRAMES = 2;
const int TOTAL_LEFT_FRAMES   = 2;
const int TOTAL_RIGHT_FRAMES  = 2; 



enum TamagotchiState {
  STATE_LEFT,
  STATE_CENTER,
  STATE_RIGHT
};

TamagotchiState currentState = STATE_CENTER; 
int currentFrame = 0;
int currCount = 0;

void setup() {
  Serial.begin(115200);

  // Initialize display
  if (!display.begin(0x3D)) {
    Serial.println(F("SSD1327 setup failed"));
  } else {
		Serial.println("Board initialized");
	}

  pinMode(BUTTON_LEFT, INPUT);
  pinMode(BUTTON_CENTER, INPUT);
  pinMode(BUTTON_RIGHT, INPUT);

  display.clearDisplay();
	display.setRotation(2);
  display.display();
}

void loop() {
if (digitalRead(BUTTON_LEFT) == HIGH) {
    if (currentState != STATE_LEFT) {
      currentState = STATE_LEFT;
      currentFrame = 0; // Reset frame counter to prevent out-of-bounds crashes
			Serial.println("left");
    } } else if (digitalRead(BUTTON_CENTER) == HIGH) {
    if (currentState != STATE_CENTER) {
      currentState = STATE_CENTER;
      currentFrame = 0;
			Serial.println("Button center");
    }
  }
  else if (digitalRead(BUTTON_RIGHT) == HIGH) {
    if (currentState != STATE_RIGHT && TOTAL_RIGHT_FRAMES > 0) {
      currentState = STATE_RIGHT;
      currentFrame = 0;
			Serial.println("Button right");
    }
  }

  const unsigned char* frameToDraw = nullptr;
  int totalFrames = 0;

  switch (currentState) {
    case STATE_LEFT:
      frameToDraw = leftFrames[currentFrame];
      totalFrames = TOTAL_LEFT_FRAMES;
      break;
      
    case STATE_CENTER:
      frameToDraw = centerFrames[currentFrame];
      totalFrames = TOTAL_CENTER_FRAMES;
      break;
      
    case STATE_RIGHT:
        frameToDraw = rightFrames[currentFrame];
        totalFrames = TOTAL_RIGHT_FRAMES;
      break;
  }

  display.fillScreen(SSD1327_WHITE); 
  
  if (frameToDraw != nullptr) {
     display.drawBitmap(0, 0, frameToDraw, ANIMAL_WIDTH, ANIMAL_HEIGHT, SSD1327_WHITE, SSD1327_BLACK);
		 display.setCursor(5, 120);
		 display.setTextColor(SSD1327_BLACK);
		 display.setTextSize(1);
		 display.println("lab64");
  }
  
  display.display();
	
	if (currCount == FRAME_COUNT) {
		currentFrame++;
		currCount = 0;
	}
	currCount++;

  if (currentFrame >= totalFrames) {
    currentFrame = 0;
  }

  delay(20); 

}
