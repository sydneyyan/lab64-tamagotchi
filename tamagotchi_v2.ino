// State Variables to track position
int animalX = 0; 
int animalY = 0;

void setup() {
  display.begin(0x3D);
  display.clearDisplay();
  
  pinMode(BUTTON_LEFT, INPUT_PULLUP);
  pinMode(BUTTON_RIGHT, INPUT_PULLUP);
}

// int i = 0;
// const int n_frames = sizeof(epd_bitmap_allArray) / sizeof(epd_bitmap_allArray[0]);

void loop() {

  display.clearDisplay(); // Clear the previous frame completely
  // if (i >= n_frames) {
  //   i = 0;
  // }
    

  // Draw the animal at its updated coordinates
  display.drawBitmap(animalX, animalY, epd_bitmap_allArray[0], ANIMAL_WIDTH, ANIMAL_HEIGHT, SSD1327_WHITE);
  
  display.display(); // Push the image to the actual screen

  // i += 1;
  
  delay(300); // A small delay to control game speed (~30 Frames Per Second)
}