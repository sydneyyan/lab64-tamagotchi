const int epd_bitmap_allArray_LEN = 7;
const unsigned char* epd_bitmap_allArray[7] = {
	epd_bitmap_c1,
	epd_bitmap_c2,
	epd_bitmap_l1,
	epd_bitmap_l2,
	epd_bitmap_l3,
	epd_bitmap_r1,
	epd_bitmap_r2
