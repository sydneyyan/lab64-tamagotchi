  STATE_SCREAM, 
  STATE_EXERCISE, 
  STATE_WIND,
  STATE_SLEEP
};
TamagotchiState currentState = STATE_IDLE;

int currentFrame = 0;
int selectedIconIndex = 0;

// --- Millis Timing Constants ---
unsigned long lastRenderTime = 0;
const unsigned long RENDER_INTERVAL_MS = 200; 

// Button State Tracking
bool lastLeftState   = LOW;
bool lastCenterState = LOW;
bool lastRightState  = LOW;

void setup() {
  Serial.begin(115200);
  if (!display.begin(0x3D)) {
    Serial.println(F("SSD1327 setup failed"));
  }
  
  pinMode(BUTTON_LEFT, INPUT);
  pinMode(BUTTON_CENTER, INPUT);
  pinMode(BUTTON_RIGHT, INPUT);

  display.clearDisplay();
  display.setRotation(2);
  display.display();
}

void loop() {
  // 1. HIGH-SPEED BUTTON SCANNING
  bool currentLeft   = digitalRead(BUTTON_LEFT);
  bool currentCenter = digitalRead(BUTTON_CENTER);
  bool currentRight  = digitalRead(BUTTON_RIGHT);
  bool needsImmediateRefresh = false;

  if (currentLeft == HIGH && lastLeftState == LOW) {
    if (selectedIconIndex > 0) {
      selectedIconIndex--;
      needsImmediateRefresh = true; 
    }
  }
  else if (currentRight == HIGH && lastRightState == LOW) {
    if (selectedIconIndex < TOTAL_ICONS - 1) {
      selectedIconIndex++;
      needsImmediateRefresh = true; 
    }
  }
  else if (currentCenter == HIGH && lastCenterState == LOW) {
    if (selectedIconIndex == 0)      currentState = STATE_SCREAM;     
    else if (selectedIconIndex == 1) currentState = STATE_SLEEP;   
    else if (selectedIconIndex == 2) currentState = STATE_WIND;    
    else if (selectedIconIndex == 3) currentState = STATE_EXERCISE;    
    
    currentFrame = 0; 
    needsImmediateRefresh = true;
  }

  lastLeftState   = currentLeft;
  lastCenterState = currentCenter;
  lastRightState  = currentRight;

  // 2. RENDERING TIMING CONTROL
  unsigned long currentMillis = millis();
  
  if (currentMillis - lastRenderTime >= RENDER_INTERVAL_MS || needsImmediateRefresh) {
    if (!needsImmediateRefresh) {
      currentFrame++;
    }
    lastRenderTime = currentMillis; 

    // Clear the screen completely to a fresh white background
    display.fillScreen(SSD1327_WHITE); 

    // --- DRAW SEPARATOR LINE ---
    display.drawFastHLine(0, 96, 128, SSD1327_BLACK);

    // --- DRAW CHARACTER (Top Half) ---
    const unsigned char* frameToDraw = nullptr;
    int totalFrames = 0;

    if (currentState == STATE_IDLE) { // <-- NEW: Handles idle rendering
      totalFrames = TOTAL_IDLE_FRAMES;
      frameToDraw = idleFrames[currentFrame % totalFrames];
    } else if (currentState == STATE_EXERCISE) {
      totalFrames = TOTAL_EXERCISE_FRAMES;
      frameToDraw = exerciseFrames[currentFrame % totalFrames];
    } else if (currentState == STATE_SCREAM) {
      totalFrames = TOTAL_SCREAM_FRAMES;
      frameToDraw = screamFrames[currentFrame % totalFrames];
    } else if (currentState == STATE_WIND) {
      totalFrames = TOTAL_WIND_FRAMES;
      frameToDraw = windFrames[currentFrame % totalFrames];
    } else {
      totalFrames = TOTAL_SLEEP_FRAMES;
      frameToDraw = sleepFrames[currentFrame % totalFrames];
    }

    if (frameToDraw != nullptr) {
       int charX = (128 - ANIMAL_WIDTH) / 2;
       int charY = (96 - ANIMAL_HEIGHT) / 2; 
       
       display.drawBitmap(charX, charY, frameToDraw, ANIMAL_WIDTH, ANIMAL_HEIGHT, SSD1327_WHITE, SSD1327_BLACK);
			 
    }
		if (currentState == STATE_SLEEP) {
			display.setTextSize(2);
			display.setTextColor(SSD1327_BLACK);
			z_counter = z_counter % NUM_Z_FRAMES; 
			if (z_counter >= NUM_FIRST_Z){
				display.setCursor(100, 10); 
				display.print("z");

				if 	(z_counter >= NUM_SECOND_Z){		
					display.setCursor(110, 5); 
					display.print("z");
				}
			}
			z_counter += 1;
		}

			if (currentState == STATE_WIND) {

			wind_counter = wind_counter % TOTAL_WIND_FRAMES; 
			if (wind_counter >= NUM_WIND_START && wind_counter <= NUM_WIND_STOP){
				display.drawBitmap(97, 60, epd_bitmap_wind, 30, 20, SSD1327_WHITE, SSD1327_BLACK); // MAGIC NUMBERS, FIX
			}
			wind_counter += 1;


		}



    // --- DRAW MENU ICONS (Bottom Half) ---
    int menuY = 105; 
    int spacing = 128 / (TOTAL_ICONS + 1); 

    for (int i = 0; i < TOTAL_ICONS; i++) {
      int iconX = (spacing * (i + 1)) - (ICON_WIDTH / 2);
      
      if (i == selectedIconIndex) {
        display.drawBitmap(iconX, menuY, menuIcons[i], ICON_WIDTH, ICON_HEIGHT, SSD1327_BLACK, SSD1327_WHITE);
      } else {
        display.drawBitmap(iconX, menuY, menuIcons[i], ICON_WIDTH, ICON_HEIGHT, SSD1327_WHITE, SSD1327_BLACK);
      }
    }

    // --- DRAWING TEXT ("lab64") ---
    display.setTextSize(1);
    display.setTextColor(SSD1327_BLACK); 
    display.setCursor(5, 86); 
    display.print("lab64");

    display.display();

    if (currentFrame >= totalFrames * requiredLoops) {
      currentFrame = 0; 
      if (currentState != STATE_IDLE) {
         currentState = STATE_IDLE; // <-- Reverts back to IDLE STATE after animations finish
      }
    }
  }
}