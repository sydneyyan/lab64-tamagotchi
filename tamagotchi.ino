const unsigned char* animationList[NUM_FRAMES] = {
  bunny, 
  bunny2, 
  bunny3
};


// =========================================================================


// --- Helper Function to Draw the Static Screens ---
void updateDisplay(int imageIndex) {
  display.clearDisplay();

  if (imageIndex == 0) {
    display.drawBitmap(0, 0, bunny, SHARP_WIDTH, SHARP_HEIGHT, WHITE, BLACK);
  } else if (imageIndex == 1) {
    display.drawBitmap(0, 0, bunny2, SHARP_WIDTH, SHARP_HEIGHT, WHITE, BLACK); 
  } else if (imageIndex == 2) {
    display.drawBitmap(0, 0, bunny3, SHARP_WIDTH, SHARP_HEIGHT, WHITE, BLACK); 
  }
  
  display.setTextSize(2);             
  display.setTextColor(BLACK, WHITE); 
  display.setCursor(10, 10);          
  display.print("** lab64 **");             
  
  display.refresh();
}


void setup() {
  Serial.begin(9600);
  
  // init outputs
  pinMode(LED_CHARGE, OUTPUT);
  pinMode(BUZZER, OUTPUT);
  digitalWrite(LED_CHARGE, LOW); 
  analogWrite(BUZZER, 0);

  // init inputs
  pinMode(BTN1_RIGHT, INPUT);
  pinMode(BTN2_MID, INPUT);
  pinMode(BTN3_LEFT, INPUT);

  // init display
  Serial.println("Starting Display...");
  if (!display.begin()) {
    Serial.println("Failed to initialize display!");
    while (1); 
  }
  updateDisplay(currentImage);
}


void loop() {
  // Play animation (right button)
  int rightButtonState = digitalRead(BTN1_RIGHT);

  if (rightButtonState == HIGH && lastRightButtonState == LOW) {
    wasAnimating = true;
  }
  lastRightButtonState = rightButtonState;

  while (wasAnimating) {
    display.clearDisplay();
    display.drawBitmap(0, 0, animationList[currentAnimFrame], SHARP_WIDTH, SHARP_HEIGHT, WHITE, BLACK);
    display.refresh();
    currentAnimFrame = (currentAnimFrame + 1) % NUM_FRAMES;

    // Animation Speed: 100ms delay = roughly 10 frames per second.
    // Decrease this number to make it faster, increase to make it slower
    delay(200);

    // Any button stops the animation
    if (digitalRead(BTN1_RIGHT) == HIGH ||
        digitalRead(BTN2_MID) == HIGH ||
        digitalRead(BTN3_LEFT) == HIGH) {
      // Wait for all buttons to be released before resuming normal input
      while (digitalRead(BTN1_RIGHT) == HIGH ||
             digitalRead(BTN2_MID) == HIGH ||
             digitalRead(BTN3_LEFT) == HIGH) {
        delay(10);
      }
      wasAnimating = false;
      currentAnimFrame = 0;
      updateDisplay(currentImage);
      lastRightButtonState = LOW;
      lastMiddleButtonState = LOW;
    }
  }


  // Slideshow mode (middle button)
  int middleButtonState = digitalRead(BTN2_MID);

  if (middleButtonState == HIGH && lastMiddleButtonState == LOW) {
    currentImage = (currentImage + 1) % 3;
    updateDisplay(currentImage);
    delay(50);
  }
  lastMiddleButtonState = middleButtonState;


  // Left button -- TODO map to something else
  if (digitalRead(BTN3_LEFT) == HIGH) {
    digitalWrite(LED_CHARGE, HIGH);
  } else {
    digitalWrite(LED_CHARGE, LOW);
  }

  delay(10); // Short delay for loop stability
}